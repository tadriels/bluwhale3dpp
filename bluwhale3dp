// STL File Upload
document.getElementById('stl').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function(event) {
    const arrayBuffer = event.target.result;
    fileWeight = estimateSTLWeight(arrayBuffer);
    
    document.getElementById('upload-status').innerText = `✓ File loaded: ${file.name} (~${fileWeight.toFixed(2)}g)`;
    updateQuote();
  };
  reader.readAsArrayBuffer(file);
});

function estimateSTLWeight(arrayBuffer) {
  const view = new Float32Array(arrayBuffer);
  let volume = 0;
  
  for (let i = 84; i < view.length; i += 12) {
    const x1 = view[i];
    const y1 = view[i + 1];
    const z1 = view[i + 2];
    
    if (i + 11 < view.length) {
      const x2 = view[i + 3];
      const y2 = view[i + 4];
      const z2 = view[i + 5];
      
      const x3 = view[i + 6];
      const y3 = view[i + 7];
      const z3 = view[i + 8];
      
      volume += Math.abs((x1 * (y2 * z3 - y3 * z2) - y1 * (x2 * z3 - x3 * z2) + z1 * (x2 * y3 - x3 * y2)) / 6);
    }
  }
  
  const densityPLA = 1.24;
  const weight = (volume / 1000) * densityPLA;
  
  return Math.max(weight, 5);
}

