<script>
const products = [
  { name: '3D Printed Headphone Stand', category: 'headphone-stands', price: 89.99 },
  { name: '3D Printed Headphone Stand (Blue)', category: 'headphone-stands', price: 89.99 },
  { name: 'Keychains', category: 'keychains', price: 34.95 },
  { name: '3D Printed Business Card', category: 'business-cards', price: 19.07 },
  { name: 'Scrub Diddy', category: 'fidgets', price: 31.40 },
  { name: 'Articulated Pencil Holder', category: 'fidgets', price: 50.30 },
  { name: 'Customizable Letters & Numbers', category: 'fidgets', price: 16.87 },
  { name: 'Transforming Chess Piece', category: 'fidgets', price: 65.99 },
  { name: 'T13 Multi Color Blue & Purple', category: 'fidgets', price: 19.07 }
];

let cart = [];
let total = 0;
let customQuoteTotal = 0;
let fileWeight = 0;

const materialPrices = {
  'PLA': 20,
  'PETG': 25,
  'ABS': 30,
  'TPU': 40,
  'Nylon': 50,
  'Resin': 80
};

const qualityCosts = {
  'standard': 5.00,
  'high': 15.00,
  'ultra': 25.00
};

function showPage(pageId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const page = document.getElementById(pageId);
  if (page) {
    page.classList.add('active');
    window.scrollTo(0, 0);
  }
  if (pageId === 'shop') renderProducts('all');
  if (pageId === 'checkout') initPayPal();
}

function renderProducts(category = 'all') {
  const container = document.getElementById('products-grid');
  container.innerHTML = '';
  let filtered = category === 'all' ? products : products.filter(p => p.category === category);

  filtered.forEach((p, i) => {
    const card = document.createElement('div');
    card.className = 'card p-6 flex flex-col justify-between';
    card.innerHTML = `
      <div class='h-48 bg-gradient-to-br from-blue-200 to-blue-100 rounded mb-4 flex items-center justify-center text-blue-400 text-2xl font-medium'>3D Print</div>
      <h3 class='text-lg font-semibold mb-2'>${p.name}</h3>
      <p class='text-gray-500 mb-4 font-semibold'>CA$${p.price.toFixed(2)}</p>
      <button class='btn w-full' onclick='addToCart(${i})'>Add to Cart</button>
    `;
    container.appendChild(card);
  });
}

function addToCart(i) {
  cart.push(products[i]);
  total += products[i].price;
  renderCart();
}

function removeFromCart(i) {
  total -= cart[i].price;
  cart.splice(i, 1);
  renderCart();
}

function renderCart() {
  let html = '';
  cart.forEach((p, i) => {
    html += `<div class='flex justify-between items-center py-2 border-b'><span class='font-medium text-sm'>${p.name}</span><div class='flex items-center'><span>CA$${p.price.toFixed(2)}</span><span class='cart-item-remove' onclick='removeFromCart(${i})'>✕</span></div></div>`;
  });
  
  if (cart.length === 0) {
    html = '<p class="text-gray-500 text-center py-4">Your cart is empty</p>';
  }

  document.getElementById('cart-preview-items').innerHTML = html;
  document.getElementById('cart-preview-total').innerText = 'CA$' + total.toFixed(2);
  document.getElementById('cart-count').innerText = cart.length;
}

function toggleCartDropdown() {
  document.getElementById('cart-preview').classList.toggle('hidden');
}

// Custom Quote Functions
function calculateFilamentUsage(weight, infill) {
  // Calculate actual filament used based on infill and weight
  // Infill affects volume, so we estimate: actual_weight = (weight * infill) / 100
  const estimatedFilament = (weight * infill) / 100;
  return Math.max(estimatedFilament, weight * 0.3); // Minimum 30% of original weight for structure
}

function updateQuote() {
  const material = document.getElementById('material-type').value;
  const quality = document.getElementById('print-quality').value;
  const infill = parseInt(document.getElementById('infill').value) || 20;

  let materialCost = 0;
  let qualityCost = 0;
  let filamentUsage = 0;

  if (fileWeight > 0) {
    filamentUsage = calculateFilamentUsage(fileWeight, infill);
    
    if (material && materialPrices[material]) {
      // Convert grams to kg and multiply by price per kg
      materialCost = (filamentUsage / 1000) * materialPrices[material];
    }
  }

  if (quality && qualityCosts[quality]) {
    qualityCost = qualityCosts[quality];
  }

  const baseCost = 10.00;
  customQuoteTotal = materialCost + qualityCost + baseCost;

  // Update display
  document.getElementById('file-weight-display').innerText = fileWeight.toFixed(2) + 'g';
  document.getElementById('filament-usage-display').innerText = filamentUsage.toFixed(2) + 'g';
  document.getElementById('material-cost').innerText = 'CA$' + materialCost.toFixed(2);
  document.getElementById('quality-cost').innerText = 'CA$' + qualityCost.toFixed(2);
  document.getElementById('total-estimate').innerText = 'CA$' + customQuoteTotal.toFixed(2);
  document.getElementById('custom-quote-total').innerText = 'CA$' + customQuoteTotal.toFixed(2);
  
  // Update modal displays
  document.getElementById('modal-file-weight').innerText = fileWeight.toFixed(2) + 'g';
  document.getElementById('modal-filament-usage').innerText = filamentUsage.toFixed(2) + 'g';
}

function requestCustomQuote() {
  if (fileWeight <= 0) {
    alert('Please upload a valid STL file');
    return;
  }
  
  const material = document.getElementById('material-type').value;
  if (!material) {
    alert('Please select a material');
    return;
