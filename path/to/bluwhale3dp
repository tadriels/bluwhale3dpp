<style>
.shop-dropdown {
    position: relative;
}
.shop-dropdown-toggle {
    cursor: pointer;
}
.shop-dropdown-menu {
    display: none;
    position: absolute;
    width: 100%;
    z-index: 10;
}
.shop-dropdown.open .shop-dropdown-menu {
    display: block;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const shopDropdown = document.querySelector('.shop-dropdown');
    const toggle = shopDropdown.querySelector('.shop-dropdown-toggle');
    toggle.addEventListener('click', function () {
        shopDropdown.classList.toggle('open');
    });
});
</script>

<ul class="shop-dropdown">
